{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "bash": "node ./dist/hook-runner.js sessionStart",
        "powershell": "node ./dist/hook-runner.js sessionStart",
        "cwd": ".",
        "timeoutSec": 10
      }
    ],
    "sessionEnd": [
      {
        "type": "command",
        "bash": "node ./dist/hook-runner.js sessionEnd",
        "powershell": "node ./dist/hook-runner.js sessionEnd",
        "cwd": ".",
        "timeoutSec": 10
      }
    ],
    "userPromptSubmitted": [
      {
        "type": "command",
        "bash": "node ./dist/hook-runner.js userPromptSubmitted",
        "powershell": "node ./dist/hook-runner.js userPromptSubmitted",
        "cwd": ".",
        "timeoutSec": 10
      }
    ],
    "preToolUse": [
      {
        "type": "command",
        "bash": "node ./dist/hook-runner.js preToolUse",
        "powershell": "node ./dist/hook-runner.js preToolUse",
        "cwd": ".",
        "timeoutSec": 10
      }
    ],
    "postToolUse": [
      {
        "type": "command",
        "bash": "node ./dist/hook-runner.js postToolUse",
        "powershell": "node ./dist/hook-runner.js postToolUse",
        "cwd": ".",
        "timeoutSec": 10
      }
    ],
    "errorOccurred": [
      {
        "type": "command",
        "bash": "node ./dist/hook-runner.js errorOccurred",
        "powershell": "node ./dist/hook-runner.js errorOccurred",
        "cwd": ".",
        "timeoutSec": 10
      }
    ]
  }
}
